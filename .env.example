# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# Necesario para correr migraciones con `npm run migrate`
# Supabase Dashboard → Project Settings → Database → Password
SUPABASE_DB_PASSWORD=tu-password-de-postgres

# IA: auto prioriza Gemini cuando ambas claves estan configuradas
AI_PROVIDER=auto

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Anthropic / Claude (opcional como proveedor o fallback)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Business Profile API (OAuth 2.0)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# Opcional: usar solo si la app corre detras de un proxy y el host publico no coincide con la request.
# GOOGLE_OAUTH_BASE_URL=https://tu-dominio.com
